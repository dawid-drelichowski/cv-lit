    "@html-eslint/eslint-plugin": "^0.62.0",
    "@percy/cli": "^1.32.2",
    "@percy/playwright": "^1.1.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "lit-analyzer": "^2.0.3",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1",
