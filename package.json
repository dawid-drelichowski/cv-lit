{
  "name": "cv-lit-element",
  "version": "2.0.0",
  "description": "My CV as LitElement's components",
  "source": "src/index.html",
  "type": "module",
  "scripts": {
    "build": "parcel build",
    "format": "prettier src/* --write",
    "lint": "npm run lint:lit-analyzer && npm run lint:eslint",
    "lint:eslint": "eslint 'src/**/*.ts'",
    "lint:lit-analyzer": "lit-analyzer",
    "start": "parcel"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawid-drelichowski/cv-lit-element.git"
  },
  "keywords": [
    "CV",
    "LitElement"
  ],
  "author": "Dawid Drelichowski",
  "license": "ISC",
  "devDependencies": {
    "@parcel/transformer-typescript-tsc": "^2.12.0",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "eslint": "8.26.0",
    "lit-analyzer": "^1.2.1",
    "parcel": "^2.14.2",
    "prettier": "^2.7.1"
  },
  "dependencies": {
    "lit-element": "^3.2.2"
  }
}
