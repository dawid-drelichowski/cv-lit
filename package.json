    "@percy/playwright": "^1.0.8",
    "@playwright/test": "^1.53.1",
    "@types/node": "^22.15.30",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.1",
    "globals": "^16.2.0",
    "lit-analyzer": "^2.0.3",
    "prettier": "^3.5.3",
    "typescript-eslint": "^8.34.1",
